<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="OpenCart Suite">

    <listeners>
        <listener class-name="com.opencart.utilities.TestListener"/>

        <listener class-name="com.opencart.utilities.ExtentListener"/>

    </listeners>

    <test name="Smoke Tests">

        <classes>

            <class name="com.opencart.testcases.HomePageTest"/>
            <class name="com.opencart.testcases.RegisterTest"/>
            <class name="com.opencart.testcases.LoginTest"/>
            <class name="com.opencart.testcases.InvalidLoginTest"/>
            <class name="com.opencart.testcases.LogoutTest"/>
            <class name="com.opencart.testcases.SearchTest"/>
            <class name="com.opencart.testcases.AddToWishlistTest"/>
            <class name="com.opencart.testcases.AddToCartTest"/>
            <class name="com.opencart.testcases.RemoveFromWishlistTest"/>
            <class name="com.opencart.testcases.LoginDDTTest"/>

        </classes>

    </test>

</suite>